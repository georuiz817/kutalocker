# Copy to .env.local. Stripe: use test mode keys (prefix sk_test_ / pk_test_) unless you opt into live.
#
# Test payments (Stripe test mode only):
#   Card: 4242 4242 4242 4242
#   Expiry: any future date
#   CVC: any 3 digits
#
# When you intentionally switch to live keys, set in .env:
#   STRIPE_ALLOW_LIVE_KEYS=true

STRIPE_SECRET_KEY=sk_test_your_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: live keys opt-in (do not set for local / staging test mode)
# STRIPE_ALLOW_LIVE_KEYS=true
